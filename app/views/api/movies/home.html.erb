
<% page = @pagination.fetch(:page) %>
<% page_size = @pagination.fetch(:page_size) %>
<% total = @pagination.fetch(:total) %>
<% total_pages = (total.to_f / page_size).ceil %>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="keywords" content="电影,在线观影,高清电影,豆瓣高分,华语电影,欧美电影,搞笑,动漫,无厘头>">
    <title>电影首页</title>
    <%# 1 %>
    <link rel="canonical" href="<%= request.base_url + '/movies' +'?' + params.permit(:title, :region, :rating_min, :categories).to_query %>" />

    <%# 2 json ld%>
    <script type="application/ld+json">
        {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "天天电影网",
        "url": "<%= request.base_url %>",
        "description": "免费高清电影在线观看平台，支持按片名、地区、类型、导演、演员、评分、时长智能筛选。",
        "potentialAction": {
            "@type": "SearchAction",
            "target": "<%= request.base_url %>/movies?title={search_term_string}&region={region}&rating_min={rating_min}",
            "query-input": "required name=search_term_string"
        }
        }
    </script>

    <%# 3 %>
    <!-- 允许索引 -->
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
    
    <!-- 仅对百度 替换为你的百度站长验证码-->
    <meta name="baidu-site-verification" content="your_baidu_code_here"> 
    
    <%
    # 安全设置最大可索引页码
    max_indexable_page = [100, total_pages].min
    %>
    <% if page > max_indexable_page %>
    <meta name="robots" content="noindex, follow">
    <meta name="googlebot" content="noindex, follow">
    <!--针对百度 -->
    <meta name="baidu-spider" content="noindex, follow">
    <% end %>
      
</head>

<div class="container">
  <h1>电影首页</h1>

  <% if @movies.blank? %>
    <div>暂无数据</div>
  <% else %>

  <div class="search">
    <form action="/home" method="get">
    <div class="search_item">
        <input type="text" placeholder="电影名" name="title" value="<%= params[:title] %>">
        <input type="text" placeholder="地区" name="region" value="<%= params[:region] %>">
        <input type="number" placeholder="时长>=" name="duration_minutes_from" value="<%= params[:duration_minutes_from] %>">
        <input type="number" placeholder="时长<=" name="duration_minutes_to" value="<%= params[:duration_minutes_to] %>">
        <input type="number" placeholder="评分>=" name="rating_min" value="<%= params[:rating_min] %>">
        <input type="number" placeholder="评分<=" name="rating_max" value="<%= params[:rating_max] %>">
        <input type="text" placeholder="类型" name="categories" value="<%= params[:categories] %>">
        <input type="text" placeholder="导演" name="directors" value="<%= params[:directors] %>">
        <input type="text" placeholder="演员" name="actors" value="<%= params[:actors] %>">
    </div>

    <div class="dateSel">
        <input type="date" placeholder="上映日期 ≥" onclick="this.showPicker()" name="release_date_from" value="<%= params[:release_date_from] %>">
        <input type="date" placeholder="上映日期 ≤" onclick="this.showPicker()" name="release_date_to" value="<%= params[:release_date_to] %>">
    </div>

    <div class="search_but">
        <button type="submit" class="btn">搜索</button>
    </div>
    </form>
  </div>



    <div class="list">
      <% @movies.each do |movie| %>
        <div class="item" onclick="window.open('/dtl/<%= movie.id %>')" style="cursor: pointer;">
          <div class="poster">
            <img src="<%= movie.poster_url %>" alt="<%= movie.title %>">
          </div>
          <div class="title">
            <%= movie.title %>
          </div>
        </div>
      <% end %>
    </div>


    <div class="pagination">
      <div class="pre_page">
        <% if page > 1 %>
          <%= link_to "上一页", url_for(params.permit(:page, :page_size).merge(page: page - 1, page_size: page_size)), class: "btn" %>
        <% end %>
      </div>

      <div class="page">
        <span class="meta"><%= page %> / <%= total_pages %></span>
      </div>

      <div class="next_page">
        <% if page < total_pages %>
          <%= link_to "下一页", url_for(params.permit(:page, :page_size).merge(page: page + 1, page_size: page_size)), class: "btn" %>
        <% end %>
      </div>
    </div>
 <% end %>
</div>

<style>
    body{
        background-color: #0b1020;
    }
    
    h1 {
        color: #fff;
        font-size: 24px;
        font-weight: bold;
        text-align: center;
        margin-bottom: 20px;
    }

  .list {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 6px;
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 6px;
    padding: 10px 0;
    background: #0b1020;
    color: #fff;
  }

  .item {
    border: 1px solid #ccc;
    margin: 10px;
    border-radius: 5px;
    min-width: 0;
  }

  .poster img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 4px;
  }

  .item .title {
    font-size: 14px;
    font-weight: bold;
    text-align: center;
    margin-top: 10px;
  }

  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 20px;
    gap: 12px;
    color: #fff;
  }

  .pagination .btn {
    display: inline-block;
    padding: 8px 14px;
    border: 1px solid #ccc;
    border-radius: 6px;
    text-decoration: none;
    color: black;
    background: #fff;
  }

  .pagination .meta {
    font-size: 14px;
    font-weight: 600;
  }

  .search{
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 10px;
    gap: 6px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 6px;
    padding: 10px;
    margin-bottom: 10px;
  }


  .search_item input {
    width: 20%;
    padding: 10px;
    margin: 10px 0;
    border: 1px solid rgba(255, 255, 255, 0.35);
    background-color: rgba(11, 16, 32, 0.6);
    border-radius: 6px;
    font-size: 14px;
  }

  .search_but{
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 20px;
    gap: 12px;
  }

  .search_but .btn {
    display: inline-block;
    padding: 8px 14px;
    margin-bottom: 10px;
    border: 1px solid #ccc;
    border-radius: 6px;
    text-decoration: none;
    background: #fff;
  }

  .dateSel input {
    width: 20%;
    padding: 10px;
    margin: 10px 0;
    border: 1px solid rgba(255, 255, 255, 0.35);
    background-color: rgba(11, 16, 32, 0.6);
    border-radius: 6px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
  }

  /* WebKit 系（Chrome/Safari）对原生日期控件文本/图标的调整 */
  input[type="date"]::-webkit-calendar-picker-indicator {
  display: none;
  -webkit-appearance: none;
}
</style>