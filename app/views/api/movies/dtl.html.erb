<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>电影详情</title>
  <script>
  console.log("<%= @movie_dtl[:title] %>");
  console.log("<%= @movie_dtl[:categories] %>");
  console.log("<%= @movie_dtl[:region] %>");
  console.log("<%= @movie_dtl[:duration_minutes] %>");
  console.log("<%= @movie_dtl[:release_date] %>");
  console.log("<%= @movie_dtl[:drama] %>");
  console.log("<%= @movie_dtl[:directors] %>");
  console.log("<%= @movie_dtl[:actors] %>");
  </script>
</head>

<div id="movie_id">
  <div class="container">
    <a class="back" href="/home">← 返回</a>
  </div>

  <div id="movie">
    <div class="dtl">
      <div class="dtl_left">
        <div class="dtl_poster">
          <img src="<%= @movie_dtl[:poster_url] %>" alt="<%= @movie_dtl[:title] %>">
        </div>
      </div>
     
      <div class="dtl_right">
        <div class="dtl_title"><%= @movie_dtl[:title] %></div>

        <div class="dtl_categories">
          <% @movie_dtl[:categories].each do |item| %>
           <span class="divider"> <%= item %> </span>
          <% end %>
        </div>

        <div class="dtl_meta"><%= @movie_dtl[:region] %> / <%= @movie_dtl[:duration_minutes] %> 分钟</div>
        <div class="dtl_meta">上映时间：<%= @movie_dtl[:release_date] %></div>

        <div class="dtl_detail">
          <div class="dtl_sug">详情</div>
          <div class="dtl_content"><%= @movie_dtl[:drama] %></div>
        </div>
      </div>
    </div>

    <div class="directors">
      <% @movie_dtl[:directors].each do |director| %>
        <div class="director">
          <div class="img"><img src="<%= director["image"] %>" alt="<%= director["name"] %>"></div>
          <div class="name"><%= director["name"] %></div>
        </div>
      <% end %>
    </div>

    <div class="casts">
      <% @movie_dtl[:actors].each do |cast| %>
        <div class="cast">
          <div class="img"><img src="<%= cast["image"] %>" alt="<%= cast["name"] %>" title="<%= cast["name"] %> / <%= cast["role"] %>"></div>
          <div class="name"><%= cast["name"] %></div>
          <div class="role"><%= cast["role"] %></div>
        </div>
      <% end %>
    </div>

    <div class="subtitle">剧照</div>

  </div>

</div>

<style>
      body{
        background-color: #0b1020;
        color: #fff;
    }
    #movie{
      display: flex;
      flex-direction: column;
      margin-top: 20px;
      gap: 12px;
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 6px;
      padding: 12px;
    }



    .dtl{
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
    }

    .dtl_left{
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    
    .dtl_right{
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 360px;
    }

    .dtl_poster img{
      width: 280px;
      height: 360px;
      border-radius: 10px;
      display: block;
    }

    .dtl_title{
      font-size: 26px;
      font-weight: 800;
    }

    .divider{
      color: rgba(255, 255, 255, 0.8);
      font-size: 14px;
      line-height: 1.6;
      border:1px solid rgba(255, 255, 255, 0.6);
      border-radius: 6px;
      margin: 0 4px;
      padding: 0 4px;
    }

     .dtl_categories,.dtl_meta{
      color: rgba(255, 255, 255, 0.8);
      font-size: 16px;
      font-weight: 700;
      line-height: 1.6;
    }

    .dtl_sug{
      font-size: 14px;
      font-weight: 700;
      border-left: 4px solid rgba(208, 4, 4, 0.72);
      padding-left: 10px;
      font-size: 16px;
      font-weight: 900;
      margin: 10px 0 0 0;
    }

    .dtl_content{
      color: rgba(255, 255, 255, 0.85);
      font-size: 14px;
      line-height: 1.8;
      white-space: pre-wrap;
    }
    .dtl_detail{
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .directors {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: 12px;
      align-items: start;
      border: 1px solid red;
    }

    .director{
      display: flex;
      flex-direction: column;
      gap: 6px;
      text-align: center;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 10px;
      padding: 10px;
      color: rgba(255, 255, 255, 0.75);
      font-size: 13px;
    }
 
    .director .img img{
      width: 100%;
      max-width: 120px;
      aspect-ratio: 3 / 4;
      object-fit: cover;
      border-radius: 10px;
      display: block;
    }
    .casts {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: 12px;
      align-items: start;
      border: 1px solid red;
    }

    .cast{
      display: flex;
      flex-direction: column;
      gap: 6px;
      align-items: center;
      text-align: center;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 10px;
      padding: 10px;
      background: rgba(11, 16, 32, 0.4);
      color: rgba(255, 255, 255, 0.75);
      font-size: 13px;
      max-height: 200px;
      overflow: hidden;
    }
    
    .casts .img img{
      width: 100%;
      max-width: 120px;
      aspect-ratio: 3 / 4;
      object-fit: cover;
      border-radius: 10px;
      display: block;
    }
</style>